# MongoDB Connection String
MONGODB_URI=mongodb://localhost:27017/whackamole
# Or use MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/whackamole?retryWrites=true&w=majority

# Server Port
PORT=5000

# CORS Allowed Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://your-frontend.vercel.app

# Node Environment
NODE_ENV=development
